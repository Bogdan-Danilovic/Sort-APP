# ============================================================
# MergeKit — Environment varijable
# Kopirajte ovaj fajl u .env.local i popunite vrednosti
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
# Pronađite u: Supabase Dashboard → Settings → API

# URL vašeg Supabase projekta (obavezan)
NEXT_PUBLIC_SUPABASE_URL=https://vaš-projekat-id.supabase.co

# Anon/public API ključ (obavezan, bezbedno je javno prikazati)
NEXT_PUBLIC_SUPABASE_ANON_KEY=vaš-anon-ključ-ovde

# Service role ključ (NIKAD ne izlagati u browser-u, samo server-side)
# Koristi se samo za admin operacije (opciono)
# SUPABASE_SERVICE_ROLE_KEY=vaš-service-role-ključ-ovde

# ─── Google OAuth (opciono) ───────────────────────────────────
# Konfigurišite u: Supabase Dashboard → Authentication → Providers → Google
# Zatim dobijete Client ID i Secret iz Google Cloud Console
# Ove vrednosti se konfigurišu direktno u Supabase konzoli, ne ovde.
# Ostavite prazno ako ne koristite Google OAuth.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── App URL ─────────────────────────────────────────────────
# URL vaše aplikacije (za OAuth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Next.js ─────────────────────────────────────────────────
# Tajni ključ za Next.js (auto-generiše se, možete ostaviti prazno)
# NEXTAUTH_SECRET=vaš-tajni-ključ
